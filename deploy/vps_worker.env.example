# VPS MCP worker node (no public traffic)
APP_ENV=production
APP_DEBUG=false

DATABASE_URL=mysql+pymysql://USER:PASSWORD@db-host:3306/scig_chat?charset=utf8mb4

MCP_SUPERVISOR_ENABLED=true

# Cleanup on one worker only
CLEANUP_ENABLED=true
CLEANUP_DAYS=30
CLEANUP_INTERVAL_MINUTES=360

# Shared secrets / DB
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ADMIN_MASTER_CODE_HASH=
TOKEN_ENC_KEY=GENERATE_FERNET_KEY_HERE
PASSWORD_MIN_LENGTH=10
TRUST_PROXY_HEADERS=false
LOG_LEVEL=INFO
