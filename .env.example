# FastAPI
APP_NAME=SciG Mode MCP
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# MySQL
DATABASE_URL=mysql+pymysql://USER:PASSWORD@127.0.0.1:3306/scig_chat?charset=utf8mb4

# Security
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ADMIN_MASTER_CODE_HASH=
TOKEN_ENC_KEY=GENERATE_FERNET_KEY_HERE
TOKEN_EXPIRE_MINUTES=480
PASSWORD_MIN_LENGTH=10
ADMIN_ALLOWED_IPS=
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
FORCE_HTTPS=true
TRUST_PROXY_HEADERS=true
ALLOWED_HOSTS=your-domain.example,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://your-domain.example
CORS_ALLOW_ORIGINS=https://your-domain.example
CORS_ALLOW_CREDENTIALS=true

# Mode -> PSID mapping
MODE_PSID_MAP=psikolog=psid_1,coding_expert=psid_2,curhat=psid_3,matematika_dasar=psid_4

# =================================================================
# MCP (Model Context Protocol) — Koneksi ke Xiaozhi AI
# =================================================================
#
# CARA MENDAPATKAN MCP TOKEN:
# 1. Login ke https://xiaozhi.me → masuk Dashboard/Console
# 2. Buka konfigurasi Smart Agent (智能体)
# 3. Di halaman Role Config (角色配置), lihat bagian kanan bawah
# 4. Copy URL MCP Endpoint yang tertera (format: wss://api.xiaozhi.me/mcp/?token=XXXX)
# 5. Paste URL tersebut sebagai nilai SCIG_MCP_TOKEN di bawah
#
# CATATAN PENTING:
# - Token ini menghubungkan server Anda ke Xiaozhi AI sebagai MCP Server
# - Setiap smart agent punya MCP endpoint sendiri (token unik)
# - Jika token berubah di xiaozhi.me, update juga di sini
# - User juga bisa mengelola token lewat dashboard web atau aplikasi mobile
#
# FORMAT TOKEN:
#   wss://api.xiaozhi.me/mcp/?token=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
MCP_SUPERVISOR_ENABLED=true
SCIG_MCP_TOKEN=wss://api.xiaozhi.me/mcp/?token=YOUR_TOKEN_HERE
MCP_RECONNECT_DELAY=5
MCP_MAX_RECONNECT_DELAY=60

# Jangan dikunci kalau mau multi device
FORCE_DEVICE_ID=

# Logging
LOG_LEVEL=INFO

# Cleanup
CLEANUP_ENABLED=true
CLEANUP_DAYS=30
CLEANUP_INTERVAL_MINUTES=360
