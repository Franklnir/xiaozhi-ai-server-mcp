# VPS API node (no MCP workers)
APP_ENV=production
APP_DEBUG=false

DATABASE_URL=mysql+pymysql://USER:PASSWORD@db-host:3306/scig_chat?charset=utf8mb4

MCP_SUPERVISOR_ENABLED=false

# Cleanup off here (run on one worker only)
CLEANUP_ENABLED=false

# Security / HTTPS
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ADMIN_MASTER_CODE_HASH=
TOKEN_ENC_KEY=GENERATE_FERNET_KEY_HERE
TOKEN_EXPIRE_MINUTES=480
PASSWORD_MIN_LENGTH=10
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
FORCE_HTTPS=true
TRUST_PROXY_HEADERS=true
ALLOWED_HOSTS=your-domain.example,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://your-domain.example
CORS_ALLOW_ORIGINS=https://your-domain.example
CORS_ALLOW_CREDENTIALS=true
ADMIN_ALLOWED_IPS=
LOG_LEVEL=INFO
